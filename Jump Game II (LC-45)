class Solution:
    def jump(self, nums: List[int]) -> int:
        count = 0
        d = len(nums) - 1

        while d > 0:
            min = -1
            for i in range(d - 1, -1, -1):
                if i + nums[i] >= d:
                    min = i
            d = min
            count += 1

        return count
